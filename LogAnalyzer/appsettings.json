{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=loganalyzer;Username=loganalyzer;Password=loganalyzer"
  },
  "OpenAI": {
    "ApiKey": "<YOUR_OPENAI_API_KEY>",
    "Model": "gpt-4o-mini",
    "MaxLogCharacters": 8000,
    "MaxPromptLogCharacters": 65536
  },
  "Graylog": {
    "BaseUrl": "http://localhost:9000",
    "ApiToken": "<YOUR_GRAYLOG_API_TOKEN>",
    "Query": "*",
    "TimeRangeMinutes": 5,
    "PageSize": 250,
    "MaxLogsPerCycle": 2000,
    "RequestTimeoutSeconds": 20,
    "MaxRetries": 3,
    "RetryDelayMilliseconds": 500
  },
  "PeriodicAnalysis": {
    "IntervalMinutes": 15,
    "MaxDistinctLines": 60,
    "MaxLinesSentToOpenAi": 12
  },
  "Webhook": {
    "Url": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
