<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>LogAnalyzer.Api</AssemblyName>
    <RootNamespace>LogAnalyzer.Api</RootNamespace>
    <UserSecretsId>b8f4e5c2-1a3d-4f6e-9b2c-8e7d6c5b4a31</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.6.2" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="8.0.11">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\LogAnalyzer.Domain\LogAnalyzer.Domain.csproj" />
    <ProjectReference Include="..\LogAnalyzer.Infrastructure\LogAnalyzer.Infrastructure.csproj" />
    <ProjectReference Include="..\LogAnalyzer.AI\LogAnalyzer.AI.csproj" />
    <ProjectReference Include="..\LogAnalyzer.Processor\LogAnalyzer.Processor.csproj" />
    <ProjectReference Include="..\LogAnalyzer.ServiceDefaults\LogAnalyzer.ServiceDefaults.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\Dockerfile">
      <Link>Dockerfile</Link>
    </None>
    <None Include="..\docker-compose.yml">
      <Link>docker-compose.yml</Link>
    </None>
    <Content Remove="configuration.template.json" />
    <None Include="configuration.template.json" />
  </ItemGroup>
</Project>
