# ------------------------------------------------------------------------------
# Docker Compose ONLY — postgres, pgadmin, mock-log-producer (GELF sink).
# Copy to ".env" if you want overrides; compose defaults match these values.
#
# Does NOT configure ASP.NET. Application settings live in:
#   LogAnalyzer/appsettings*.json + dotnet user-secrets (see configuration.template.json).
#
# Graylog: only the GELF UDP address belongs here (where the producer ships logs).
# Graylog REST (BaseUrl, ApiToken) for the API periodic job → appsettings / secrets.
#
# If POSTGRES_* change, update ConnectionStrings:DefaultConnection (same DB/user/pass).
# ------------------------------------------------------------------------------

# --- PostgreSQL container ---
POSTGRES_DB=loganalyzer
POSTGRES_USER=loganalyzer
POSTGRES_PASSWORD=loganalyzer

# --- pgAdmin container ---
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin

# --- mock-log-producer → Graylog GELF UDP input ---
GRAYLOG_GELF_ADDRESS=udp://host.docker.internal:12201
