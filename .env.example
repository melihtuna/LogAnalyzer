OpenAI__ApiKey=your_openai_api_key_here
OpenAI__Model=gpt-4o-mini
OpenAI__MaxLogCharacters=8000
OpenAI__MaxPromptLogCharacters=65536
PeriodicAnalysis__IntervalMinutes=15
PeriodicAnalysis__MaxDistinctLines=60
PeriodicAnalysis__MaxLinesSentToOpenAi=12
Graylog__BaseUrl=http://host.docker.internal:9000
Graylog__AuthMode=Basic
Graylog__ApiToken=
Graylog__Query=*
Graylog__TimeRangeMinutes=5
GRAYLOG_GELF_ADDRESS=udp://host.docker.internal:12201
